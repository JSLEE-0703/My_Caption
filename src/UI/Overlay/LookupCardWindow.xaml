<Window x:Class="MyCaption.UI.Overlay.LookupCardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dictionary"
        Width="420"
        MinWidth="320"
        MaxWidth="520"
        MinHeight="160"
        MaxHeight="560"
        SizeToContent="Height"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="SpinnerStyle" TargetType="Grid">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <RotateTransform Angle="0" />
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                             From="0"
                                             To="360"
                                             Duration="0:0:0.9" />
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Padding="14"
            CornerRadius="18"
            Background="#10161B"
            BorderBrush="#34424C"
            BorderThickness="1">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      MaxHeight="520">
            <StackPanel>
                <TextBlock Text="{Binding LookupWord}" FontSize="22" FontWeight="SemiBold" Foreground="#F3F2EA" />
                <TextBlock Margin="0,4,0,0"
                           Text="{Binding LookupPhonetic}"
                           Foreground="#8FE2D6"
                           FontSize="14"
                           Visibility="{Binding HasLookupPhonetic, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <StackPanel Margin="0,10,0,0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Visibility="{Binding IsLookupLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Grid Width="18"
                          Height="18"
                          Margin="0,0,8,0"
                          Style="{StaticResource SpinnerStyle}">
                        <Ellipse Stroke="#35505E"
                                 StrokeThickness="2.4" />
                        <Path Stroke="#8FE2D6"
                              StrokeThickness="2.4"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              Data="M 9,1 A 8,8 0 0 1 17,9" />
                    </Grid>
                    <TextBlock Text="正在拉起词典并查询，请稍候..."
                               Foreground="#8FE2D6"
                               FontSize="12"
                               VerticalAlignment="Center" />
                </StackPanel>
                <ItemsControl Margin="0,10,0,0"
                              ItemsSource="{Binding LookupMeanings}"
                              Visibility="{Binding HasLookupMeanings, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Margin="0,0,0,6" Text="{Binding}" TextWrapping="Wrap" Foreground="#D8E0E5" FontSize="13" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding LookupExample}"
                           TextWrapping="Wrap"
                           Foreground="#F4D08E"
                           FontSize="12"
                           Visibility="{Binding HasLookupExample, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding LookupRawContent}"
                           TextWrapping="Wrap"
                           Foreground="#D8E0E5"
                           FontSize="13"
                           Visibility="{Binding HasLookupRawContent, Converter={StaticResource BooleanToVisibilityConverter}}" />
                <TextBlock Margin="0,10,0,0"
                           Text="{Binding LookupStatusMessage}"
                           TextWrapping="Wrap"
                           Foreground="#AAB7C0"
                           FontSize="12"
                           Visibility="{Binding HasLookupStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
        </ScrollViewer>
    </Border>
</Window>
