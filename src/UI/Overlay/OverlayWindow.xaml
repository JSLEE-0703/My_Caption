<Window x:Class="MyCaption.UI.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Overlay"
        Width="840"
        Height="190"
        MinWidth="520"
        MinHeight="120"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Topmost="True"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <Style x:Key="TokenButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#F3F2EA" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="TokenChrome" Padding="1,0" CornerRadius="6" Background="Transparent">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TokenChrome" Property="Background" Value="#35FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="TokenChrome" Property="Background" Value="#55FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="1" />
                                <Setter TargetName="TokenChrome" Property="Background" Value="Transparent" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ResizeThumbStyle" TargetType="Thumb">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Opacity" Value="0" />
            <Setter Property="Visibility" Value="{Binding IsInteractive, Converter={StaticResource BooleanToVisibilityConverter}}" />
        </Style>
    </Window.Resources>

    <Grid>
        <Border x:Name="Backdrop"
                Margin="6"
                CornerRadius="24"
                BorderThickness="1"
                BorderBrush="#2C3943"
                Opacity="{Binding BackgroundOpacity}"
                MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#1F2429" Offset="0" />
                    <GradientStop Color="#151A1F" Offset="1" />
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border x:Name="HintBar"
                    Grid.Row="0"
                    Margin="0,0,0,10"
                    Padding="12,6"
                    CornerRadius="14"
                    Background="#143944"
                    MouseLeftButtonDown="Chrome_MouseLeftButtonDown"
                    Visibility="{Binding IsInteractive, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Foreground="#8FE2D6"
                           FontSize="12"
                           Text="Hold Alt to move, resize, or click words." />
            </Border>

            <Border x:Name="OriginalPanel"
                    Grid.Row="1"
                    Padding="2"
                    Background="Transparent"
                    MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                <ItemsControl ItemsSource="{Binding OriginalTokens}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Style="{StaticResource TokenButtonStyle}"
                                    Click="WordTokenButton_Click"
                                    IsEnabled="{Binding CanClick}"
                                    Tag="{Binding}">
                                <TextBlock Text="{Binding Text}" FontSize="{Binding DataContext.OriginalFontSize, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="#F3F2EA" />
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <Border x:Name="TranslationPanel"
                    Grid.Row="2"
                    Margin="0,8,0,0"
                    Padding="2"
                    Background="Transparent"
                    MouseLeftButtonDown="Chrome_MouseLeftButtonDown">
                <TextBlock x:Name="TranslatedTextBlock"
                           Foreground="#F4D08E"
                           FontSize="{Binding TranslationFontSize}"
                           TextWrapping="Wrap"
                           Text="{Binding TranslatedText}" />
            </Border>
        </Grid>

        <Popup x:Name="LookupPopup" AllowsTransparency="True" Placement="Bottom" StaysOpen="False">
            <Border Width="340" Padding="14" CornerRadius="18" Background="#10161B" BorderBrush="#34424C" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="{Binding LookupWord}" FontSize="22" FontWeight="SemiBold" Foreground="#F3F2EA" />
                    <TextBlock Margin="0,4,0,0" Text="{Binding LookupPhonetic}" Foreground="#8FE2D6" FontSize="14" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding LookupSummary}" TextWrapping="Wrap" Foreground="#D8E0E5" FontSize="13" />
                    <TextBlock Margin="0,10,0,0" Text="{Binding LookupHint}" TextWrapping="Wrap" Foreground="#AAB7C0" FontSize="12" />
                </StackPanel>
            </Border>
        </Popup>

        <Thumb x:Name="TopThumb" Height="10" HorizontalAlignment="Stretch" VerticalAlignment="Top" Cursor="SizeNS" DragDelta="TopThumb_DragDelta" Style="{StaticResource ResizeThumbStyle}" />
        <Thumb x:Name="BottomThumb" Height="10" HorizontalAlignment="Stretch" VerticalAlignment="Bottom" Cursor="SizeNS" DragDelta="BottomThumb_DragDelta" Style="{StaticResource ResizeThumbStyle}" />
        <Thumb x:Name="LeftThumb" Width="10" HorizontalAlignment="Left" VerticalAlignment="Stretch" Cursor="SizeWE" DragDelta="LeftThumb_DragDelta" Style="{StaticResource ResizeThumbStyle}" />
        <Thumb x:Name="RightThumb" Width="10" HorizontalAlignment="Right" VerticalAlignment="Stretch" Cursor="SizeWE" DragDelta="RightThumb_DragDelta" Style="{StaticResource ResizeThumbStyle}" />
    </Grid>
</Window>
