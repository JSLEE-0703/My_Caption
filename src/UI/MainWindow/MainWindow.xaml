<Window x:Class="MyCaption.UI.MainWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My Caption"
        Width="840"
        Height="620"
        MinWidth="760"
        MinHeight="560"
        Background="#11161B"
        WindowStartupLocation="CenterScreen"
        FontFamily="Bahnschrift">
    <Window.Resources>
        <Style x:Key="ProviderComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="#F3F2EA" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ClosedStateButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          Background="Transparent"
                                          BorderThickness="0"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <Border x:Name="ClosedStateBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="18" />
                                        </Grid.ColumnDefinitions>
                                        <ContentPresenter Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Left"
                                                          Content="{TemplateBinding SelectionBoxItem}"
                                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                                        <Path Grid.Column="1"
                                              Width="10"
                                              Height="6"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Data="M 0 0 L 5 6 L 10 0"
                                              Stroke="#57D18C"
                                              StrokeThickness="1.8"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              StrokeLineJoin="Round" />
                                    </Grid>
                                </Border>
                            </ToggleButton>
                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   PopupAnimation="Fade">
                                <Border Margin="0,4,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="#11161B"
                                        BorderBrush="#32404D"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer MaxHeight="240"
                                                  CanContentScroll="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="ClosedStateBorder" Property="MinHeight" Value="30" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ClosedStateBorder" Property="BorderBrush" Value="#57D18C" />
                            </Trigger>
                            <Trigger SourceName="ClosedStateButton" Property="IsMouseOver" Value="True">
                                <Setter TargetName="ClosedStateBorder" Property="BorderBrush" Value="#4C6274" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#8A949D" />
                                <Setter TargetName="ClosedStateBorder" Property="Opacity" Value="0.75" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ProviderComboBoxItemStyle" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="#F3F2EA" />
            <Setter Property="Background" Value="#11161B" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="18" />
                                </Grid.ColumnDefinitions>
                                <ContentPresenter VerticalAlignment="Center"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                                <Path x:Name="SelectedGlyph"
                                      Grid.Column="1"
                                      Width="10"
                                      Height="8"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Right"
                                      Data="M 0 4 L 3 7 L 10 0"
                                      Stroke="#57D18C"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Visibility="Collapsed" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#24303A" />
                                <Setter Property="Foreground" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#11161B" />
                                <Setter Property="Foreground" Value="#F3F2EA" />
                                <Setter TargetName="SelectedGlyph" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  PanningMode="VerticalOnly">
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Padding="18" CornerRadius="22" Background="#1C232B" BorderBrush="#2F3B46" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock FontSize="31" FontWeight="SemiBold" Foreground="#F3F2EA" Text="My Caption" />
                        <TextBlock Margin="0,8,0,0" Foreground="#B9C3CC" FontSize="14" TextWrapping="Wrap"
                                   Text="Windows Live Captions capture + low-distraction overlay + Alt-only interaction. Translation and lookup stay pluggable so the core loop remains fast and stable." />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Width="180"
                            Padding="12,8"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top"
                            CornerRadius="16"
                            Background="#102E3A">
                        <TextBlock Foreground="#8FE2D6"
                                   FontSize="13"
                                   Text="{Binding StatusBadgeText}"
                                   TextAlignment="Center"
                                   TextTrimming="CharacterEllipsis" />
                    </Border>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Margin="0,0,10,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F3F2EA" Text="Pipeline" />
                        <TextBlock Margin="0,12,0,0" FontSize="13" Foreground="#B9C3CC" Text="{Binding ProviderText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#8FE2D6" Text="{Binding TranslationStatusText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0" FontSize="13" Foreground="#B9C3CC" Text="{Binding LookupProviderText}" TextWrapping="Wrap" />
                        <TextBlock Margin="0,8,0,0" FontSize="12" Foreground="#8FE2D6" Text="{Binding LookupStatusText}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="10,0,0,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F3F2EA" Text="Interaction" />
                        <TextBlock Margin="0,12,0,0" FontSize="13" Foreground="#B9C3CC"
                                   Text="Default state is click-through. Hold Alt to temporarily enter interaction mode, drag the overlay, or click an English word to open the dictionary popup." />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" Margin="0,16,0,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                <StackPanel>
                    <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F3F2EA" Text="Controls" />
                    <WrapPanel Margin="0,14,0,0">
                        <Button x:Name="StartStopButton" Width="170" Height="36" Margin="0,0,12,12" Click="StartStopButton_Click"
                                Background="#2C645D" Foreground="#F4FFF9" BorderThickness="0"
                                Content="{Binding StartStopButtonText}" />
                        <Button x:Name="OverlayToggleButton" Width="170" Height="36" Margin="0,0,12,12" Click="OverlayToggleButton_Click"
                                Background="#32404D" Foreground="#F3F2EA" BorderThickness="0" Content="Hide Overlay" />
                        <Button Width="170" Height="36" Margin="0,0,12,12" Click="ResetOverlayButton_Click"
                                Background="#32404D" Foreground="#F3F2EA" BorderThickness="0" Content="Reset Overlay Position" />
                    </WrapPanel>
                    <TextBlock Margin="0,2,0,0"
                               Foreground="#B9C3CC"
                               FontSize="12"
                               Text="{Binding StatusText}"
                               TextWrapping="NoWrap"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Margin="0,16,0,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Margin="0,0,14,0">
                        <CheckBox x:Name="OriginalOnTopCheckBox" Foreground="#F3F2EA" IsChecked="{Binding OriginalOnTop}"
                                  Checked="OriginalOnTopCheckBox_Changed" Unchecked="OriginalOnTopCheckBox_Changed"
                                  Content="Show original text above translation" />
                        <CheckBox x:Name="HideOriginalWindowCheckBox" Margin="0,12,0,0" Foreground="#F3F2EA"
                                  IsChecked="{Binding HideOriginalLiveCaptions}"
                                  Checked="HideOriginalWindowCheckBox_Changed" Unchecked="HideOriginalWindowCheckBox_Changed"
                                  Content="Hide built-in Live Captions after attach" />
                        <CheckBox x:Name="TranslationEnabledCheckBox" Margin="0,12,0,0" Foreground="#F3F2EA"
                                  IsChecked="{Binding TranslationEnabled}"
                                  Checked="TranslationEnabledCheckBox_Changed" Unchecked="TranslationEnabledCheckBox_Changed"
                                  Content="Enable translation" />
                        <CheckBox x:Name="ShowTranslationTextCheckBox" Margin="0,12,0,0" Foreground="#F3F2EA"
                                  IsChecked="{Binding ShowTranslationText}"
                                  Checked="ShowTranslationTextCheckBox_Changed" Unchecked="ShowTranslationTextCheckBox_Changed"
                                  Content="Show translation text in overlay" />
                        <TextBlock Margin="0,16,0,0" Foreground="#F3F2EA" Text="Translation provider" />
                        <ComboBox x:Name="TranslationProviderComboBox"
                                  Margin="0,8,0,0"
                                  MinHeight="30"
                                  Background="#11161B"
                                  BorderBrush="#32404D"
                                  Foreground="#E6ECE8"
                                  Style="{StaticResource ProviderComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource ProviderComboBoxItemStyle}"
                                  SelectionChanged="TranslationProviderComboBox_SelectionChanged">
                            <ComboBoxItem Tag="Stub" Content="Stub" />
                            <ComboBoxItem Tag="ExternalCli" Content="External CLI" />
                            <ComboBoxItem Tag="DeepL" Content="DeepL API" />
                            <ComboBoxItem Tag="AzureTranslator" Content="Azure Translator" />
                            <ComboBoxItem Tag="GoogleCloud" Content="Google Cloud Translation" />
                        </ComboBox>
                        <StackPanel Margin="0,16,0,0">
                            <TextBlock Foreground="#F3F2EA" Text="Source language" />
                            <TextBox x:Name="TranslationSourceLanguageTextBox"
                                     Margin="0,8,0,0"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding TranslationSourceLanguage, Mode=OneWay}"
                                     LostFocus="TranslationSourceLanguageTextBox_LostFocus"
                                     KeyDown="TranslationSourceLanguageTextBox_KeyDown" />
                            <TextBlock Margin="0,12,0,0" Foreground="#F3F2EA" Text="Target language" />
                            <TextBox x:Name="TranslationTargetLanguageTextBox"
                                     Margin="0,8,0,0"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding TranslationTargetLanguage, Mode=OneWay}"
                                     LostFocus="TranslationTargetLanguageTextBox_LostFocus"
                                     KeyDown="TranslationTargetLanguageTextBox_KeyDown" />
                        </StackPanel>
                        <StackPanel x:Name="ExternalTranslationPanel" Margin="0,16,0,0">
                            <TextBlock Margin="0,12,0,0" Foreground="#F3F2EA" Text="Executable path" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TranslationExecutablePathTextBox"
                                         MinHeight="30"
                                         Padding="8,5"
                                         Background="#11161B"
                                         BorderBrush="#32404D"
                                         Foreground="#E6ECE8"
                                         Text="{Binding TranslationExecutablePath, Mode=OneWay}"
                                         LostFocus="TranslationExecutablePathTextBox_LostFocus"
                                         KeyDown="TranslationExecutablePathTextBox_KeyDown" />
                                <Button Grid.Column="1"
                                        Width="88"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Click="BrowseTranslationExecutableButton_Click"
                                        Background="#32404D"
                                        Foreground="#F3F2EA"
                                        BorderThickness="0"
                                        Content="Browse..." />
                            </Grid>
                            <TextBlock Margin="0,12,0,0" Foreground="#F3F2EA" Text="Arguments template" />
                            <TextBox x:Name="TranslationArgumentsTemplateTextBox"
                                     Margin="0,8,0,0"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding TranslationArgumentsTemplate, Mode=OneWay}"
                                     LostFocus="TranslationArgumentsTemplateTextBox_LostFocus"
                                     KeyDown="TranslationArgumentsTemplateTextBox_KeyDown" />
                        </StackPanel>
                        <StackPanel x:Name="ApiTranslationPanel" Margin="0,16,0,0">
                            <TextBlock Foreground="#F3F2EA" Text="API URL" />
                            <TextBox x:Name="TranslationApiUrlTextBox"
                                     Margin="0,8,0,0"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding TranslationApiUrl, Mode=OneWay}"
                                     LostFocus="TranslationApiUrlTextBox_LostFocus"
                                     KeyDown="TranslationApiUrlTextBox_KeyDown" />
                            <TextBlock Margin="0,12,0,0" Foreground="#F3F2EA" Text="API key" />
                            <TextBox x:Name="TranslationApiKeyTextBox"
                                     Margin="0,8,0,0"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding TranslationApiKey, Mode=OneWay}"
                                     LostFocus="TranslationApiKeyTextBox_LostFocus"
                                     KeyDown="TranslationApiKeyTextBox_KeyDown" />
                            <StackPanel x:Name="TranslationApiRegionPanel" Margin="0,12,0,0">
                                <TextBlock Foreground="#F3F2EA" Text="Resource region (Azure only)" />
                                <TextBox x:Name="TranslationApiRegionTextBox"
                                         Margin="0,8,0,0"
                                         MinHeight="30"
                                         Padding="8,5"
                                         Background="#11161B"
                                         BorderBrush="#32404D"
                                         Foreground="#E6ECE8"
                                         Text="{Binding TranslationApiRegion, Mode=OneWay}"
                                         LostFocus="TranslationApiRegionTextBox_LostFocus"
                                         KeyDown="TranslationApiRegionTextBox_KeyDown" />
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Margin="0,16,0,0" Foreground="#F3F2EA" Text="Lookup provider" />
                        <ComboBox x:Name="LookupProviderComboBox"
                                  Margin="0,8,0,0"
                                  MinHeight="30"
                                  Background="#11161B"
                                  BorderBrush="#32404D"
                                  Foreground="#E6ECE8"
                                  Style="{StaticResource ProviderComboBoxStyle}"
                                  ItemContainerStyle="{StaticResource ProviderComboBoxItemStyle}"
                                  SelectionChanged="LookupProviderComboBox_SelectionChanged">
                            <ComboBoxItem Tag="JsonFile" Content="JSON file" />
                            <ComboBoxItem Tag="MdictCli" Content="MDict (.mdx)" />
                        </ComboBox>
                        <TextBlock Margin="0,16,0,0" Foreground="#F3F2EA" Text="Dictionary source" />
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DictionaryPathTextBox"
                                     MinHeight="30"
                                     Padding="8,5"
                                     Background="#11161B"
                                     BorderBrush="#32404D"
                                     Foreground="#E6ECE8"
                                     Text="{Binding DictionaryFilePath, Mode=OneWay}"
                                     LostFocus="DictionaryPathTextBox_LostFocus"
                                     KeyDown="DictionaryPathTextBox_KeyDown" />
                            <Button Grid.Column="1"
                                    Width="88"
                                    Height="30"
                                    Margin="10,0,0,0"
                                    Click="BrowseDictionaryButton_Click"
                                    Background="#32404D"
                                    Foreground="#F3F2EA"
                                    BorderThickness="0"
                                    Content="Browse..." />
                        </Grid>
                        <StackPanel x:Name="MdictExecutablePanel" Margin="0,16,0,0">
                            <TextBlock Foreground="#F3F2EA" Text="mdict executable" />
                            <Grid Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="MdictExecutablePathTextBox"
                                         MinHeight="30"
                                         Padding="8,5"
                                         Background="#11161B"
                                         BorderBrush="#32404D"
                                         Foreground="#E6ECE8"
                                         Text="{Binding MdictExecutablePath, Mode=OneWay}"
                                         LostFocus="MdictExecutablePathTextBox_LostFocus"
                                         KeyDown="MdictExecutablePathTextBox_KeyDown" />
                                <Button Grid.Column="1"
                                        Width="88"
                                        Height="30"
                                        Margin="10,0,0,0"
                                        Click="BrowseMdictExecutableButton_Click"
                                        Background="#32404D"
                                        Foreground="#F3F2EA"
                                        BorderThickness="0"
                                        Content="Browse..." />
                            </Grid>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Margin="14,0,0,0">
                        <TextBlock Foreground="#F3F2EA" Text="Original font size" />
                        <Slider x:Name="FontSizeSlider" Margin="0,8,0,0" Minimum="18" Maximum="40"
                                SmallChange="1" LargeChange="2" Value="{Binding FontSize}"
                                ValueChanged="FontSizeSlider_ValueChanged" />
                        <TextBlock Margin="0,12,0,0" Foreground="#F3F2EA" Text="Overlay background opacity" />
                        <Slider x:Name="OpacitySlider" Margin="0,8,0,0" Minimum="0.35" Maximum="1"
                                SmallChange="0.05" LargeChange="0.1" Value="{Binding BackgroundOpacity}"
                                ValueChanged="OpacitySlider_ValueChanged" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="4" Margin="0,16,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Margin="0,0,10,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F3F2EA" Text="Current Original" />
                        <TextBlock Margin="0,12,0,0" Foreground="#E6ECE8" FontSize="20" TextWrapping="Wrap" Text="{Binding PreviewOriginal}" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Margin="10,0,0,0" Padding="16" CornerRadius="18" Background="#171D24" BorderBrush="#29323A" BorderThickness="1">
                    <StackPanel>
                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#F3F2EA" Text="Current Translation" />
                        <TextBlock Margin="0,12,0,0" Foreground="#F5D89F" FontSize="18" TextWrapping="Wrap" Text="{Binding PreviewTranslation}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </ScrollViewer>
</Window>
